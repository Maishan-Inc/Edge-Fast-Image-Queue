{
  "name": "edge-fast-image-queue",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare edge image generation queue system with Durable Objects, D1, R2, OAuth and admin-configurable settings.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "db:local": "wrangler d1 migrations apply EDGE_FAST_IMAGE_QUEUE_DB --local",
    "db:remote": "wrangler d1 migrations apply EDGE_FAST_IMAGE_QUEUE_DB --remote",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "hono": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
