APP_NAME=Edge-Fast-Image-Queue
APP_ENV=production
APP_URL=https://example.com

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=auto

QUEUE_CONCURRENCY=3
QUEUE_GROUP_WINDOW_SECONDS=60
QUEUE_GROUP_MAX_REQUESTS=1
QUEUE_PRIORITY_TRIGGER_LENGTH=100
QUEUE_PROTECTED_RANK=50
QUEUE_PRIORITY_INSERT_START=51
QUEUE_ALLOW_GUEST=false

GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_REDIRECT_URI=https://example.com/api/auth/google/callback
GOOGLE_OAUTH_SCOPE=openid email profile

LINUXDO_OAUTH_ENABLED=false
LINUXDO_OAUTH_CLIENT_ID=
LINUXDO_OAUTH_ISSUER=https://connect.linux.do
LINUXDO_OAUTH_REDIRECT_URI=https://example.com/api/auth/linuxdo/callback
LINUXDO_OAUTH_SCOPE=openid profile email

ADSENSE_ENABLED=false
ADSENSE_CLIENT_ID=
ADSENSE_SLOT_HOME=
ADSENSE_SLOT_QUEUE=
ADSENSE_SLOT_RESULT=
